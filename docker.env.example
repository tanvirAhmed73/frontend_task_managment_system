# Copy to .env in this folder (docker compose reads it for ${VAR} substitution):
#   cp docker.env.example .env
#
# Backend on your machine (default in compose):
# NEXT_PUBLIC_API_URL=http://host.docker.internal:4000/api
# NEXT_PUBLIC_SOCKET_ORIGIN=http://host.docker.internal:4000
#
# Backend in another container on the same compose network (example):
# NEXT_PUBLIC_API_URL=http://api:4000/api
# NEXT_PUBLIC_SOCKET_ORIGIN=http://api:4000
#
# Map app to another host port:
# WEB_PORT=8080

WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://host.docker.internal:4000/api
NEXT_PUBLIC_SOCKET_ORIGIN=http://host.docker.internal:4000
